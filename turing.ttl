@prefix ns1: <http://example.org/turing#http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix ns2: <http://example.org/turing#> .
@prefix ns3: <http://example.org/turing#http://example.org/turing#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns2:He ns2:proposed "machine" ;
    ns2:wrote "paper" .

ns2:Turing ns2:diedIn "1954" ;
    ns2:participatedIn "Park" ;
    ns2:proposed "test" .

ns3:AlanTuring ns3:awarded "http://example.org/turing#OBE" ;
    ns3:birthDate "1912-06-23"^^xsd:date ;
    ns3:bornIn "http://example.org/turing#London" ;
    ns3:deathDate "1954-06-07"^^xsd:date ;
    ns3:diedIn "http://example.org/turing#Wilmslow" ;
    ns3:hasOccupation "http://example.org/turing#ComputerScientist",
        "http://example.org/turing#Cryptanalyst",
        "http://example.org/turing#Mathematician" ;
    ns3:nationality "British" ;
    ns3:participatedIn "http://example.org/turing#WWIICodebreaking" ;
    ns3:proposed "http://example.org/turing#TuringMachine",
        "http://example.org/turing#TuringTest" ;
    ns3:wrote "http://example.org/turing#ComputingMachineryAndIntelligence",
        "http://example.org/turing#OnComputableNumbers" ;
    ns1:type "http://example.org/turing#Person" .

ns3:ArtificialIntelligence ns1:type "http://example.org/turing#Concept" .

ns3:ComputationTheory ns1:type "http://example.org/turing#Concept" .

ns3:ComputerScientist ns1:type "http://example.org/turing#Occupation" .

ns3:ComputingMachineryAndIntelligence ns1:type "http://example.org/turing#Work" .

ns3:Cryptanalyst ns1:type "http://example.org/turing#Occupation" .

ns3:London ns1:type "http://example.org/turing#Location" .

ns3:Mathematician ns1:type "http://example.org/turing#Occupation" .

ns3:OBE ns1:type "http://example.org/turing#Award" .

ns3:OnComputableNumbers ns1:type "http://example.org/turing#Work" .

ns3:TuringMachine ns3:belongsTo "http://example.org/turing#ComputationTheory" ;
    ns1:type "http://example.org/turing#Concept" .

ns3:TuringTest ns3:belongsTo "http://example.org/turing#ArtificialIntelligence" ;
    ns1:type "http://example.org/turing#Concept" .

ns3:WWIICodebreaking ns1:type "http://example.org/turing#Event" .

ns3:Wilmslow ns1:type "http://example.org/turing#Location" .

